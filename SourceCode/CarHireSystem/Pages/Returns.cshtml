@page
@model CarHireSystem.Pages.ReturnsModel

<div class="section-hero" style="padding:40px 0 36px;">
    <div class="container">
        <h1 class="fw-bold mb-1" style="font-size:2rem">Return a Car</h1>
        <p class="mb-0">Select the booking you would like to return</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-7">

            @if (Model.SuccessMessage != null)
            {
                <div class="alert alert-success fw-semibold">&#10003; @Model.SuccessMessage</div>
            }

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            @if (!Model.ActiveBookings.Any())
            {
                <div class="card p-5 text-center">
                    <p class="text-muted mb-3">You have no active bookings to return.</p>
                    <a asp-page="/Search" class="btn btn-navy px-4">Browse Cars</a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var booking in Model.ActiveBookings)
                    {
                        var car = Model.CarsById.GetValueOrDefault(booking.CarID);
                        <div class="card p-4" style="border-left: 4px solid var(--eh-navy);">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="d-flex align-items-center gap-3">
                                    @if (car != null && !string.IsNullOrEmpty(car.PhotoUrl))
                                    {
                                        <img src="@car.PhotoUrl" alt="@car.Make @car.Model"
                                             style="width:72px; height:52px; object-fit:cover; border-radius:6px; flex-shrink:0;" />
                                    }
                                    <div>
                                        <p class="fw-bold mb-0">@(car != null ? $"{car.Make} {car.Model}" : $"Car #{booking.CarID}")</p>
                                        <p class="text-muted mb-0" style="font-size:0.82rem;">
                                            Booking #@booking.BookingID &nbsp;&bull;&nbsp;
                                            @booking.StartDate.ToString("dd MMM") &ndash; @booking.EndDate.ToString("dd MMM yyyy")
                                        </p>
                                        <p class="price-accent mb-0" style="font-size:0.95rem;">£@booking.TotalCost total</p>
                                    </div>
                                </div>
                                <form method="post" style="margin:0;"
                                      onsubmit="return confirm('Return @(car?.Make) @(car?.Model)? This cannot be undone.')">
                                    <input type="hidden" name="bookingId" value="@booking.BookingID" />
                                    <button type="submit" class="btn btn-navy btn-sm px-3">Return</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>
