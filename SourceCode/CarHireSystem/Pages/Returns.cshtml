@page
@model CarHireSystem.Pages.ReturnsModel

<div class="section-hero">
    <div class="container text-center">
        <h1 class="fw-700 mb-2" style="font-size:2.2rem">Return a Car</h1>
        <p class="mb-0" style="color:#ccc">Enter your booking ID to complete your return</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">

            @if (Model.SuccessMessage != null)
            {
                <div class="alert alert-success fw-500">✓ @Model.SuccessMessage</div>
            }

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <div class="card p-4">
                <h5 class="fw-600 mb-1">Vehicle Return</h5>
                <p class="text-muted mb-4" style="font-size:0.9rem">Please have your booking ID ready. You can find it on your booking confirmation.</p>
                <form method="post">
                    <div class="mb-4">
                        <label class="form-label fw-500">Booking ID</label>
                        <input type="number" name="BookingId" class="form-control form-control-lg" placeholder="e.g. 4821" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">Complete Return</button>
                </form>
            </div>

            <div class="card p-4 mt-4" style="background:#fff8f0; border-left: 4px solid #e63946;">
                <h6 class="fw-600 mb-2">Need help?</h6>
                <p class="mb-0 text-muted" style="font-size:0.85rem">Call us on <strong>0800 123 4567</strong> or email <strong>support@driveeasy.co.uk</strong></p>
            </div>
        </div>
    </div>
</div>