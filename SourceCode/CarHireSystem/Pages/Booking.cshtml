@page
@model CarHireSystem.Pages.BookingModel

<h2>Book a Car</h2>

<form method="post">
    <label>Car ID: <input type="number" name="CarId" /></label><br/>
    <label>Name: <input type="text" name="CustomerName" /></label><br/>
    <label>Email: <input type="text" name="CustomerEmail" /></label><br/>
    <label>Phone: <input type="text" name="CustomerPhone" /></label><br/>
    <label>Start Date: <input type="date" name="StartDate" /></label><br/>
    <label>End Date: <input type="date" name="EndDate" /></label><br/>
    <button type="submit">Book</button>
</form>

@if (Model.Confirmation != null)
{
    <p>Booking confirmed! Booking ID: @Model.Confirmation.BookingID</p>
    <p>Total Cost: £@Model.Confirmation.TotalCost</p>
}

@if (Model.ErrorMessage != null)
{
    <p style="color:red">@Model.ErrorMessage</p>
}