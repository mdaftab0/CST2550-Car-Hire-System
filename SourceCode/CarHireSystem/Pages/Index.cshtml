@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<div class="section-hero" style="padding: 80px 0 72px;">
    <div class="container text-center">
        <h1 class="fw-bold mb-3" style="font-size:2.8rem; letter-spacing:-0.03em">
            Drive Away Today<br/>with <span style="opacity:0.65; font-weight:400">Easy</span><span>Hire</span>
        </h1>
        <p class="mb-4" style="font-size:1.1rem; max-width:480px; margin:0 auto 24px;">
            Premium vehicles at everyday prices &mdash; search, book and go in minutes.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-page="/Search" class="btn btn-primary btn-lg px-5">Search Cars</a>
            <a asp-page="/Booking" class="btn btn-outline-light btn-lg px-5">Make a Booking</a>
        </div>
    </div>
</div>

<!-- Car carousel -->
@if (Model.AvailableCars.Length > 0)
{
    <div class="container mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-semibold mb-0">Available Now</h5>
            <a asp-page="/Search" style="font-size:0.9rem; color:var(--eh-navy);">View all &rarr;</a>
        </div>

        <div id="carCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3500">

            <!-- Indicators -->
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.AvailableCars.Length; i++)
                {
                    <button type="button" data-bs-target="#carCarousel" data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            style="background-color:var(--eh-navy); width:8px; height:8px; border-radius:50%; border:none;"
                            aria-label="Car @(i + 1)"></button>
                }
            </div>

            <!-- Slides -->
            <div class="carousel-inner" style="border-radius:12px; overflow:hidden;">
                @for (int i = 0; i < Model.AvailableCars.Length; i++)
                {
                    var car = Model.AvailableCars[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <div style="position:relative; background:var(--eh-navy); height:320px;">

                            <!-- Photo -->
                            @if (!string.IsNullOrEmpty(car.PhotoUrl))
                            {
                                <img src="@car.PhotoUrl" alt="@car.Make @car.Model"
                                     style="width:100%; height:100%; object-fit:cover; opacity:0.55;" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; background:var(--eh-navy);"></div>
                            }

                            <!-- Overlay content -->
                            <div style="position:absolute; inset:0; display:flex; flex-direction:column;
                                        justify-content:flex-end; padding:32px 40px;
                                        background:linear-gradient(to top, rgba(15,23,42,0.9) 0%, transparent 60%);">
                                <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
                                    <div>
                                        <p class="mb-1" style="color:rgba(255,255,255,0.6); font-size:0.82rem; text-transform:uppercase; letter-spacing:0.05em;">
                                            Car #@car.Id &bull; @car.Seats seats
                                        </p>
                                        <h3 class="fw-bold text-white mb-1" style="font-size:1.9rem; line-height:1.1;">
                                            @car.Make @car.Model
                                        </h3>
                                        <p class="mb-0" style="color:rgba(255,255,255,0.85); font-size:1.05rem;">
                                            £@car.PricePerDay <span style="font-size:0.85rem; opacity:0.65;">/ day</span>
                                        </p>
                                    </div>
                                    <a asp-page="/Booking" asp-route-carId="@car.Id"
                                       class="btn btn-primary px-4 py-2 fw-semibold">
                                        Book Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Prev / Next -->
            <button class="carousel-control-prev" type="button" data-bs-target="#carCarousel" data-bs-slide="prev"
                    style="width:48px;">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carCarousel" data-bs-slide="next"
                    style="width:48px;">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
}

<!-- Feature cards -->
<div class="container mb-5">
    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card p-4 h-100" style="border-top: 3px solid var(--eh-navy);">
                <h5 class="fw-semibold mb-2">Search &amp; Filter</h5>
                <p class="text-muted mb-3" style="font-size:0.9rem">Browse our full fleet and filter by daily price to find a car that fits your budget.</p>
                <a asp-page="/Search" class="btn btn-outline-primary btn-sm mt-auto">Browse Fleet</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 h-100" style="border-top: 3px solid var(--eh-navy);">
                <h5 class="fw-semibold mb-2">Instant Booking</h5>
                <p class="text-muted mb-3" style="font-size:0.9rem">Reserve your vehicle in seconds. Receive a booking ID and you&apos;re ready to go.</p>
                <a asp-page="/Booking" class="btn btn-outline-primary btn-sm mt-auto">Book Now</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 h-100" style="border-top: 3px solid var(--eh-navy);">
                <h5 class="fw-semibold mb-2">Easy Returns</h5>
                <p class="text-muted mb-3" style="font-size:0.9rem">Returning your hire car is just as simple &mdash; enter your booking ID and you&apos;re done.</p>
                <a asp-page="/Returns" class="btn btn-outline-primary btn-sm mt-auto">Return a Car</a>
            </div>
        </div>
    </div>
</div>

<!-- Call-to-action strip -->
<div style="background: var(--eh-navy); padding: 48px 0; margin-bottom: 0;">
    <div class="container text-center">
        <h3 class="fw-bold text-white mb-2">Ready to hire?</h3>
        <p style="color: rgba(255,255,255,0.65); margin-bottom: 24px;">Find your perfect car from our available fleet right now.</p>
        <a asp-page="/Search" class="btn btn-primary btn-lg px-5">Find a Car</a>
    </div>
</div>
