@page
@model CarHireSystem.Pages.ChatModel
@{
    ViewData["Title"] = "AI Assistant";
}

<div class="section-hero" style="padding:40px 0 36px;">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:2.2rem">EasyHire Assistant</h1>
        <p class="mb-0">Ask me anything about our fleet, pricing, bookings or returns</p>
    </div>
</div>

<div class="container" style="max-width:760px;">

    <!-- Chat window -->
    <div class="card p-0 mb-3" style="border-top:3px solid var(--eh-navy);">
        <div id="chat-window" style="height:460px; overflow-y:auto; padding:24px; display:flex; flex-direction:column; gap:14px;">

            @if (!Model.Messages.Any())
            {
                <div style="margin:auto; text-align:center; color:#94a3b8;">
                    <div style="font-size:2.4rem; margin-bottom:10px;">&#129302;</div>
                    <p class="mb-1 fw-semibold" style="color:#64748b;">How can I help you today?</p>
                    <p style="font-size:0.85rem;">Try: &ldquo;Show me cars under £50/day&rdquo; or &ldquo;How do I return a car?&rdquo;</p>
                </div>
            }

            @foreach (var msg in Model.Messages)
            {
                if (msg.Role == "user")
                {
                    <div style="display:flex; justify-content:flex-end;">
                        <div style="background:var(--eh-navy); color:#fff; padding:10px 16px; border-radius:18px 18px 4px 18px; max-width:75%; font-size:0.93rem; line-height:1.5;">
                            @msg.Content
                        </div>
                    </div>
                }
                else
                {
                    <div style="display:flex; justify-content:flex-start; gap:10px; align-items:flex-start;">
                        <div style="width:32px; height:32px; background:var(--eh-navy); border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:0.9rem; color:#fff;">A</div>
                        <div style="background:#f1f5f9; color:var(--eh-navy); padding:10px 16px; border-radius:4px 18px 18px 18px; max-width:78%; font-size:0.93rem; line-height:1.6; white-space:pre-wrap;">@msg.Content</div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Input -->
    <form method="post" class="d-flex gap-2 mb-2">
        <input
            type="text"
            name="UserInput"
            id="chat-input"
            class="form-control"
            placeholder="Type your message..."
            autocomplete="off"
            maxlength="500"
            required />
        <button type="submit" class="btn btn-navy px-4" style="white-space:nowrap;">Send</button>
    </form>

    <div class="d-flex justify-content-between align-items-center">
        <p class="text-muted mb-0" style="font-size:0.8rem;">Powered by Claude AI &mdash; responses may not be 100% accurate.</p>
        @if (Model.Messages.Any())
        {
            <form method="post" asp-page-handler="Clear" style="margin:0;">
                <button type="submit" class="btn btn-sm" style="font-size:0.8rem; color:#94a3b8; background:none; border:none; padding:0; cursor:pointer;">Clear chat</button>
            </form>
        }
    </div>

    <!-- Suggestion chips -->
    @if (!Model.Messages.Any())
    {
        <div class="d-flex flex-wrap gap-2 mt-4">
            @foreach (var suggestion in new[]
            {
                "Cars under £50/day",
                "What's your cheapest car?",
                "How do I make a booking?",
                "How do I return a car?",
                "What's your most premium car?"
            })
            {
                <button type="button" class="btn btn-sm" onclick="fillInput(this.innerText)"
                    style="background:#f1f5f9; color:var(--eh-navy); border:1px solid var(--eh-border); border-radius:20px; font-size:0.82rem;">
                    @suggestion
                </button>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // Scroll chat window to bottom on load
        const win = document.getElementById('chat-window');
        if (win) win.scrollTop = win.scrollHeight;

        // Populate input from suggestion chip
        function fillInput(text) {
            document.getElementById('chat-input').value = text;
            document.getElementById('chat-input').focus();
        }
    </script>
}
