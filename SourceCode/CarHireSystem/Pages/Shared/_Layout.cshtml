<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DriveEasy Car Hire</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarHireSystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #f8f9fa; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; color: #1a1a2e !important; }
        .navbar-brand span { color: #e63946; }
        .nav-link { font-weight: 500; color: #333 !important; }
        .nav-link:hover { color: #e63946 !important; }
        .btn-primary { background: #e63946; border-color: #e63946; font-weight: 600; }
        .btn-primary:hover { background: #c1121f; border-color: #c1121f; }
        .btn-outline-primary { color: #e63946; border-color: #e63946; font-weight: 600; }
        .btn-outline-primary:hover { background: #e63946; border-color: #e63946; }
        .card { border: none; box-shadow: 0 2px 12px rgba(0,0,0,0.08); border-radius: 12px; }
        .form-control:focus { border-color: #e63946; box-shadow: 0 0 0 0.2rem rgba(230,57,70,0.15); }
        footer { background: #1a1a2e; color: #aaa; padding: 30px 0; margin-top: 60px; }
        footer a { color: #e63946; text-decoration: none; }
        .section-hero { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 60px 0; margin-bottom: 40px; }
        .badge-available { background: #d4edda; color: #155724; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
        .badge-unavailable { background: #f8d7da; color: #721c24; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Drive<span>Easy</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Search">Search Cars</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Booking">Book</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Returns">Returns</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm px-3" asp-area="" asp-page="/Search">Find a Car</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h6 class="text-white fw-700 mb-2">DriveEasy Car Hire</h6>
                    <p style="font-size:0.85rem">Premium vehicles at affordable prices. Available 24/7.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-2">Quick Links</h6>
                    <ul class="list-unstyled" style="font-size:0.85rem">
                        <li><a asp-page="/Search">Search Cars</a></li>
                        <li><a asp-page="/Booking">Make a Booking</a></li>
                        <li><a asp-page="/Returns">Return a Car</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-2">Contact</h6>
                    <p style="font-size:0.85rem">support@driveeasy.co.uk<br/>0800 123 4567</p>
                </div>
            </div>
            <hr style="border-color:#333; margin-top:20px"/>
            <p style="font-size:0.8rem; text-align:center">&copy; 2026 DriveEasy - <a asp-page="/Privacy">Privacy</a></p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>