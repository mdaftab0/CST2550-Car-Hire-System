<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EasyHire Car Hire</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarHireSystem.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --eh-navy:      #0f172a;
            --eh-navy-mid:  #1e293b;
            --eh-navy-dark: #070f1e;
            --eh-white:     #ffffff;
            --eh-off-white: #f8fafc;
            --eh-border:    rgba(15, 23, 42, 0.18);
        }

        /* ── Base ─────────────────────────────── */
        body {
            font-family: 'Inter', sans-serif;
            background: var(--eh-off-white);
            color: var(--eh-navy);
        }

        /* ── Navbar ───────────────────────────── */
        .navbar {
            background: var(--eh-navy) !important;
        }
        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            color: var(--eh-white) !important;
            letter-spacing: -0.02em;
        }
        .navbar-brand span {
            color: var(--eh-white);
            opacity: 0.55;
            font-weight: 400;
        }
        .nav-link {
            font-weight: 500;
            color: rgba(255, 255, 255, 0.78) !important;
            transition: color 0.15s;
        }
        .nav-link:hover {
            color: var(--eh-white) !important;
        }
        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.3);
        }
        .navbar-toggler-icon {
            filter: invert(1);
        }

        /* ── Buttons ──────────────────────────── */
        .btn-primary {
            background: var(--eh-white);
            border-color: var(--eh-white);
            color: var(--eh-navy);
            font-weight: 600;
        }
        .btn-primary:hover,
        .btn-primary:focus,
        .btn-primary:active {
            background: #e2e8f0;
            border-color: #e2e8f0;
            color: var(--eh-navy);
        }
        .btn-outline-primary {
            color: var(--eh-navy);
            border-color: var(--eh-navy);
            font-weight: 600;
            background: transparent;
        }
        .btn-outline-primary:hover {
            background: var(--eh-navy);
            border-color: var(--eh-navy);
            color: var(--eh-white);
        }
        /* solid navy button — use class="btn btn-navy" on light backgrounds */
        .btn-navy {
            background: var(--eh-navy);
            border-color: var(--eh-navy);
            color: var(--eh-white);
            font-weight: 600;
        }
        .btn-navy:hover,
        .btn-navy:focus {
            background: var(--eh-navy-mid);
            border-color: var(--eh-navy-mid);
            color: var(--eh-white);
        }

        /* ── Cards ────────────────────────────── */
        .card {
            border: 1px solid var(--eh-border);
            box-shadow: 0 2px 12px rgba(15, 23, 42, 0.06);
            border-radius: 12px;
            background: var(--eh-white);
        }

        /* ── Form inputs ──────────────────────── */
        .form-control,
        .form-select {
            border-color: var(--eh-border);
            background: var(--eh-white);
            color: var(--eh-navy);
        }
        .form-control:focus,
        .form-select:focus {
            border-color: var(--eh-navy);
            box-shadow: 0 0 0 0.2rem rgba(15, 23, 42, 0.14);
            background: var(--eh-white);
            color: var(--eh-navy);
        }
        .form-label {
            color: var(--eh-navy);
            font-weight: 500;
        }

        /* ── Hero sections ────────────────────── */
        .section-hero {
            background: linear-gradient(135deg, var(--eh-navy) 0%, var(--eh-navy-mid) 100%);
            color: var(--eh-white);
            padding: 64px 0;
            margin-bottom: 40px;
        }
        .section-hero p {
            color: rgba(255, 255, 255, 0.68);
        }

        /* ── Footer ───────────────────────────── */
        footer {
            background: var(--eh-navy-dark);
            color: rgba(255, 255, 255, 0.58);
            padding: 36px 0;
            margin-top: 60px;
        }
        footer h6 {
            color: var(--eh-white) !important;
        }
        footer a {
            color: rgba(255, 255, 255, 0.72);
            text-decoration: none;
            transition: color 0.15s;
        }
        footer a:hover {
            color: var(--eh-white);
        }
        footer hr {
            border-color: rgba(255, 255, 255, 0.1);
            margin-top: 24px;
        }

        /* ── Availability badges ──────────────── */
        .badge-available {
            background: #d1fae5;
            color: #065f46;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .badge-unavailable {
            background: #fee2e2;
            color: #991b1b;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* ── Utility helpers ──────────────────── */
        .text-navy   { color: var(--eh-navy)  !important; }
        .bg-navy     { background: var(--eh-navy) !important; }
        .border-navy { border-color: var(--eh-navy) !important; }
        .price-accent { color: var(--eh-navy); font-weight: 700; }
    </style>
</head>
<body>
    <!-- Demo notice banner -->
    <div style="background:#854d0e; color:#fef9c3; text-align:center; font-size:0.8rem; font-weight:600; padding:7px 0; letter-spacing:0.01em;">
        &#9888; This is a demonstration website &mdash; no real bookings, payments or transactions are processed.
    </div>
    <header>
        <nav class="navbar navbar-expand-sm shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Easy<span>Hire</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Search">Search Cars</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Booking">Book</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Returns">Returns</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center gap-2">
                        <li class="nav-item">
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-primary btn-sm px-3" asp-page="/Admin/Index">Admin Panel</a>
                            }
                            else
                            {
                                <a class="btn btn-primary btn-sm px-3" asp-area="" asp-page="/Search">Find a Car</a>
                            }
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link" style="font-size:0.85rem; color:rgba(255,255,255,0.6)!important; padding-right:0">
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout" style="margin:0">
                                    <button type="submit" class="btn btn-outline-light btn-sm px-3">Sign Out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm px-3" asp-page="/Account/Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3" asp-page="/Account/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3 mb-md-0">
                    <h6 class="fw-bold mb-2">EasyHire Car Hire</h6>
                    <p style="font-size:0.85rem">Premium vehicles at affordable prices. Available 24/7.</p>
                </div>
                <div class="col-md-4 mb-3 mb-md-0">
                    <h6 class="mb-2">Quick Links</h6>
                    <ul class="list-unstyled" style="font-size:0.85rem">
                        <li><a asp-page="/Search">Search Cars</a></li>
                        <li><a asp-page="/Booking">Make a Booking</a></li>
                        <li><a asp-page="/Returns">Return a Car</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="mb-2">Contact</h6>
                    <p style="font-size:0.85rem">easyhire@fake.com<br/>0123456789</p>
                </div>
            </div>
            <hr />
            <p style="font-size:0.8rem; text-align:center">&copy; 2026 EasyHire</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- ── Floating AI Chat Widget ─────────────────────────────────── -->
    <style>
        #eh-chat-fab {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--eh-navy);
            color: #fff;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(15,23,42,0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1050;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        #eh-chat-fab:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(15,23,42,0.45); }

        #eh-chat-panel {
            position: fixed;
            bottom: 96px;
            right: 28px;
            width: 360px;
            height: 500px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(15,23,42,0.22);
            display: none;
            flex-direction: column;
            z-index: 1049;
            overflow: hidden;
        }
        #eh-chat-panel.open { display: flex; }

        #eh-chat-header {
            background: var(--eh-navy);
            color: #fff;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }
        #eh-chat-header .eh-avatar {
            width: 30px; height: 30px; border-radius: 50%;
            background: rgba(255,255,255,0.15);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; flex-shrink: 0;
        }
        #eh-chat-header .eh-title { flex: 1; font-weight: 600; font-size: 0.95rem; }
        #eh-chat-header .eh-header-btns { display: flex; gap: 6px; }
        #eh-chat-header button {
            background: none; border: none; color: rgba(255,255,255,0.7);
            font-size: 0.78rem; cursor: pointer; padding: 2px 6px;
            border-radius: 4px; transition: color 0.1s;
        }
        #eh-chat-header button:hover { color: #fff; }

        #eh-chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: #f8fafc;
        }
        .eh-msg-user {
            display: flex; justify-content: flex-end;
        }
        .eh-msg-user span {
            background: var(--eh-navy); color: #fff;
            padding: 8px 14px; border-radius: 16px 16px 4px 16px;
            max-width: 82%; font-size: 0.88rem; line-height: 1.45; word-break: break-word;
        }
        .eh-msg-bot { display: flex; gap: 8px; align-items: flex-start; }
        .eh-msg-bot .eh-bot-avatar {
            width: 26px; height: 26px; background: var(--eh-navy); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 0.7rem; font-weight: 700; flex-shrink: 0; margin-top: 2px;
        }
        .eh-msg-bot span {
            background: #fff; color: var(--eh-navy);
            padding: 8px 14px; border-radius: 4px 16px 16px 16px;
            max-width: 82%; font-size: 0.88rem; line-height: 1.5;
            white-space: pre-wrap; word-break: break-word;
            box-shadow: 0 1px 4px rgba(15,23,42,0.08);
        }
        .eh-msg-typing span { opacity: 0.6; font-style: italic; }

        #eh-chat-empty {
            margin: auto; text-align: center; color: #94a3b8;
        }
        #eh-chat-empty div { font-size: 2rem; margin-bottom: 8px; }
        #eh-chat-empty p { font-size: 0.82rem; margin: 0; }

        #eh-chat-footer {
            padding: 10px 12px;
            border-top: 1px solid var(--eh-border);
            display: flex;
            gap: 8px;
            flex-shrink: 0;
            background: #fff;
        }
        #eh-chat-input {
            flex: 1; border: 1px solid var(--eh-border); border-radius: 8px;
            padding: 8px 12px; font-size: 0.88rem; font-family: inherit;
            color: var(--eh-navy); outline: none;
        }
        #eh-chat-input:focus { border-color: var(--eh-navy); }
        #eh-chat-send {
            background: var(--eh-navy); color: #fff; border: none;
            border-radius: 8px; padding: 8px 14px; font-size: 0.88rem;
            font-weight: 600; cursor: pointer; transition: background 0.15s;
        }
        #eh-chat-send:hover { background: var(--eh-navy-mid); }
        #eh-chat-send:disabled { opacity: 0.5; cursor: not-allowed; }

        .eh-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
        .eh-chip {
            background: #f1f5f9; color: var(--eh-navy);
            border: 1px solid var(--eh-border); border-radius: 20px;
            font-size: 0.78rem; padding: 4px 10px; cursor: pointer;
            transition: background 0.1s;
        }
        .eh-chip:hover { background: #e2e8f0; }
    </style>

    <!-- FAB button -->
    <button id="eh-chat-fab" onclick="ehChatToggle()" title="AI Assistant">&#128172;</button>

    <!-- Chat panel -->
    <div id="eh-chat-panel">
        <div id="eh-chat-header">
            <div class="eh-avatar">A</div>
            <span class="eh-title">EasyHire Assistant</span>
            <div class="eh-header-btns">
                <button onclick="ehChatClear()" title="Clear chat">Clear</button>
                <button onclick="ehChatToggle()" title="Close" style="font-size:1rem;">&#215;</button>
            </div>
        </div>
        <div id="eh-chat-messages">
            <div id="eh-chat-empty">
                <div>&#129302;</div>
                <p>How can I help you?</p>
            </div>
        </div>
        <div id="eh-chat-footer">
            <input id="eh-chat-input" type="text" placeholder="Ask me anything..." maxlength="500"
                   onkeydown="if(event.key==='Enter'){ehChatSend();}" />
            <button id="eh-chat-send" onclick="ehChatSend()">Send</button>
        </div>
    </div>

    <script>
        let ehChatOpen = false;
        const ehChips = ["Cars under £50/day", "What's the cheapest car?", "How do I book?", "How do I return a car?"];

        function ehChatToggle() {
            ehChatOpen = !ehChatOpen;
            document.getElementById('eh-chat-panel').classList.toggle('open', ehChatOpen);
            if (ehChatOpen) {
                ehLoadHistory();
                setTimeout(() => document.getElementById('eh-chat-input').focus(), 80);
            }
        }

        async function ehLoadHistory() {
            try {
                const res = await fetch('/Chat?handler=Messages');
                const msgs = await res.json();
                ehRenderMessages(msgs);
            } catch { /* silently fail */ }
        }

        function ehRenderMessages(msgs) {
            const container = document.getElementById('eh-chat-messages');
            container.innerHTML = '';
            if (!msgs || msgs.length === 0) {
                container.innerHTML = `
                    <div id="eh-chat-empty" style="margin:auto;text-align:center;color:#94a3b8;">
                        <div style="font-size:2rem;margin-bottom:8px;">&#129302;</div>
                        <p style="font-size:0.82rem;margin:0 0 12px;">How can I help you today?</p>
                        <div class="eh-chips">${ehChips.map(c => `<button class="eh-chip" onclick="ehFill(this)">${c}</button>`).join('')}</div>
                    </div>`;
                return;
            }
            msgs.forEach(m => ehAppendMessage(m.role, m.content));
            ehScrollBottom();
        }

        function ehAppendMessage(role, text) {
            const container = document.getElementById('eh-chat-messages');
            // Remove empty state if present
            const empty = document.getElementById('eh-chat-empty');
            if (empty) empty.remove();

            const div = document.createElement('div');
            if (role === 'user') {
                div.className = 'eh-msg-user';
                div.innerHTML = `<span>${ehEscape(text)}</span>`;
            } else {
                div.className = 'eh-msg-bot';
                div.innerHTML = `<div class="eh-bot-avatar">A</div><span>${ehEscape(text)}</span>`;
            }
            container.appendChild(div);
            ehScrollBottom();
            return div;
        }

        function ehScrollBottom() {
            const c = document.getElementById('eh-chat-messages');
            c.scrollTop = c.scrollHeight;
        }

        function ehEscape(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
        }

        async function ehChatSend() {
            const input = document.getElementById('eh-chat-input');
            const sendBtn = document.getElementById('eh-chat-send');
            const text = input.value.trim();
            if (!text) return;

            input.value = '';
            sendBtn.disabled = true;
            ehAppendMessage('user', text);

            // Show typing indicator
            const typingDiv = ehAppendMessage('assistant', '...');
            typingDiv.classList.add('eh-msg-typing');

            try {
                const fd = new FormData();
                fd.append('userInput', text);
                const res = await fetch('/Chat?handler=Send', { method: 'POST', body: fd });
                const data = await res.json();
                typingDiv.remove();
                ehAppendMessage('assistant', data.reply || 'Sorry, no response received.');
            } catch {
                typingDiv.remove();
                ehAppendMessage('assistant', 'Sorry, something went wrong. Please try again.');
            } finally {
                sendBtn.disabled = false;
                input.focus();
            }
        }

        async function ehChatClear() {
            try {
                const fd = new FormData();
                await fetch('/Chat?handler=ClearHistory', { method: 'POST', body: fd });
                ehRenderMessages([]);
            } catch { /* silently fail */ }
        }

        function ehFill(btn) {
            document.getElementById('eh-chat-input').value = btn.innerText;
            document.getElementById('eh-chat-input').focus();
        }
    </script>
    <!-- ── End Chat Widget ─────────────────────────────────────────── -->
</body>
</html>
