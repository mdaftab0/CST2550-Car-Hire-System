@page
@model CarHireSystem.Pages.Account.ExternalLoginCallbackModel

@if (Model.DebugMessage != null)
{
    <div class="container mt-5">
        <div class="alert alert-danger">
            <h5>OAuth Debug Info</h5>
            <p>@Model.DebugMessage</p>
            <a asp-page="/Account/Login" class="btn btn-outline-danger btn-sm">Back to Login</a>
        </div>
    </div>
}
