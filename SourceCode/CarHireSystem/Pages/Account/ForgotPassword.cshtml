@page
@model CarHireSystem.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="section-hero">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:2.2rem">Reset Password</h1>
        <p class="mb-0">Enter your email to receive a reset link</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @if (Model.Submitted)
            {
                @if (Model.ResetLink != null)
                {
                    <div class="card p-4">
                        <div class="mb-3" style="background:#d1fae5; color:#065f46; border:1px solid #6ee7b7; border-radius:8px; padding:12px 16px; font-size:0.9rem;">
                            A reset link has been generated. In production this would be emailed — use the link below to reset your password.
                        </div>
                        <div class="mb-3 p-3" style="background:var(--eh-off-white); border:1px solid var(--eh-border); border-radius:8px; word-break:break-all; font-size:0.78rem;">
                            <a href="@Model.ResetLink" style="color:var(--eh-navy)">@Model.ResetLink</a>
                        </div>
                        <a asp-page="/Account/Login" class="btn btn-navy btn-sm px-4">Back to Sign In</a>
                    </div>
                }
                else
                {
                    <div class="card p-4">
                        <div class="mb-3" style="background:#d1fae5; color:#065f46; border:1px solid #6ee7b7; border-radius:8px; padding:12px 16px; font-size:0.9rem;">
                            If an account with that email exists, a reset link will be sent.
                        </div>
                        <a asp-page="/Account/Login" class="btn btn-navy btn-sm px-4">Back to Sign In</a>
                    </div>
                }
            }
            else
            {
                <div class="card p-4">
                    <h5 class="fw-semibold mb-4">Forgot your password?</h5>
                    <form method="post">
                        <div class="mb-4">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="Email" class="form-control"
                                   placeholder="you@example.com" value="@Model.Email"
                                   autocomplete="email" required />
                        </div>
                        <button type="submit" class="btn btn-navy w-100 py-2">Send Reset Link</button>
                    </form>
                </div>

                <p class="text-center mt-3" style="font-size:0.9rem">
                    Remembered it?
                    <a asp-page="/Account/Login" class="fw-semibold text-navy">Sign in</a>
                </p>
            }

        </div>
    </div>
</div>
