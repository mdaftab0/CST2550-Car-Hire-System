@page
@model CarHireSystem.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="section-hero">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:2.2rem">Sign In</h1>
        <p class="mb-0">Welcome back to EasyHire</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <div class="card p-4">
                <h5 class="fw-semibold mb-4">Account Login</h5>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="Email" class="form-control" placeholder="you@example.com"
                               value="@Model.Email" autocomplete="email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="Password" class="form-control" placeholder="••••••••"
                               autocomplete="current-password" />
                    </div>
                    <div class="mb-4 form-check">
                        <input type="checkbox" name="RememberMe" class="form-check-input" id="rememberMe"
                               @(Model.RememberMe ? "checked" : "") />
                        <label class="form-check-label" for="rememberMe" style="color:var(--eh-navy)">Remember me</label>
                    </div>
                    <button type="submit" class="btn btn-navy w-100 py-2">Sign In</button>
                </form>
            </div>

            <p class="text-center mt-3" style="font-size:0.9rem">
                Don&apos;t have an account?
                <a asp-page="/Account/Register" class="fw-semibold text-navy">Register here</a>
            </p>
        </div>
    </div>
</div>
