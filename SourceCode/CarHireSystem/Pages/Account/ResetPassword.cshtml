@page
@model CarHireSystem.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="section-hero">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:2.2rem">Set New Password</h1>
        <p class="mb-0">Choose a strong password for your account</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @if (Model.ResetSucceeded)
            {
                <div class="card p-4 text-center">
                    <div class="mb-3" style="background:#d1fae5; color:#065f46; border:1px solid #6ee7b7; border-radius:8px; padding:12px 16px; font-size:0.9rem;">
                        Your password has been reset successfully.
                    </div>
                    <a asp-page="/Account/Login" class="btn btn-navy px-5 py-2">Sign In</a>
                </div>
            }
            else
            {
                @if (Model.ErrorMessage != null)
                {
                    <div class="mb-3" style="background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; border-radius:8px; padding:12px 16px; font-size:0.9rem;">
                        @Model.ErrorMessage
                    </div>
                }

                <div class="card p-4">
                    <h5 class="fw-semibold mb-4">New Password</h5>
                    <form method="post">
                        <input type="hidden" name="Email" value="@Model.Email" />
                        <input type="hidden" name="Token" value="@Model.Token" />

                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" id="newPass" name="NewPassword" class="form-control"
                                   placeholder="••••••••" autocomplete="new-password" required />
                            <ul class="mt-2 mb-0 ps-0" id="reqList" style="font-size:0.78rem; color:#94a3b8; list-style:none;">
                                <li id="req-len">&#9675; At least 8 characters</li>
                                <li id="req-upper">&#9675; Uppercase letter</li>
                                <li id="req-lower">&#9675; Lowercase letter</li>
                                <li id="req-digit">&#9675; Number</li>
                            </ul>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Confirm Password</label>
                            <input type="password" id="confirmPass" name="ConfirmPassword" class="form-control"
                                   placeholder="••••••••" autocomplete="new-password" required />
                            <div id="matchFeedback" class="form-text mt-1" style="font-size:0.8rem"></div>
                        </div>

                        <button type="submit" class="btn btn-navy w-100 py-2">Reset Password</button>
                    </form>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
<script>
    const newPass     = document.getElementById('newPass');
    const confirmPass = document.getElementById('confirmPass');
    const matchFb     = document.getElementById('matchFeedback');

    function checkReq(id, pass) {
        const rules = { 'req-len': pass.length >= 8, 'req-upper': /[A-Z]/.test(pass),
                        'req-lower': /[a-z]/.test(pass), 'req-digit': /[0-9]/.test(pass) };
        const el = document.getElementById(id);
        const met = rules[id];
        el.textContent = (met ? '✓ ' : '○ ') + el.textContent.replace(/^[✓○] /, '');
        el.style.color  = met ? '#16a34a' : '#94a3b8';
    }

    newPass.addEventListener('input', () => {
        ['req-len','req-upper','req-lower','req-digit'].forEach(id => checkReq(id, newPass.value));
        if (confirmPass.value) checkMatch();
    });

    function checkMatch() {
        if (!confirmPass.value) { matchFb.textContent = ''; return; }
        if (confirmPass.value === newPass.value) {
            matchFb.textContent = '✓ Passwords match'; matchFb.style.color = '#16a34a';
        } else {
            matchFb.textContent = '✗ Passwords do not match'; matchFb.style.color = '#dc2626';
        }
    }
    confirmPass.addEventListener('input', checkMatch);
</script>
}
