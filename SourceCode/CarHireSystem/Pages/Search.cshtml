@page
@model CarHireSystem.Pages.SearchModel

<div class="section-hero">
    <div class="container text-center">
        <h1 class="fw-bold mb-2" style="font-size:2.2rem">Find Your Perfect Car</h1>
        <p class="mb-0">Search our fleet by daily price range</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="card p-4">
                <h5 class="fw-semibold mb-3">Search by Price</h5>
                <form method="post">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Min Price (£/day)</label>
                            <input type="number" name="minPrice" class="form-control" placeholder="e.g. 20"
                                   value="@(Model.MinPrice.HasValue ? Model.MinPrice.ToString() : "")" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Max Price (£/day)</label>
                            <input type="number" name="maxPrice" class="form-control" placeholder="e.g. 100"
                                   value="@(Model.MaxPrice.HasValue ? Model.MaxPrice.ToString() : "")" />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-navy w-100">Search Cars</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (Model.Results != null)
    {
        <h5 class="fw-semibold mb-3">
            @if (Model.IsFiltered)
            {
                @($"{Model.Results.Count} car(s) found")
            }
            else
            {
                @("Our Fleet")
            }
        </h5>

        @if (Model.Results.Count == 0)
        {
            <div class="card p-4 text-center text-muted">
                <p class="mb-0">No cars matched that price range. Try a wider range.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @for (int i = 0; i < Model.Results.Count; i++)
                {
                    var car = Model.Results.Get(i);
                    <div class="col-md-4">
                        <div class="card overflow-hidden h-100" style="border-top: 3px solid var(--eh-navy);">
                            @if (!string.IsNullOrEmpty(car.PhotoUrl))
                            {
                                <img src="@car.PhotoUrl" alt="@car.Make @car.Model"
                                     style="width:100%; height:160px; object-fit:cover;" />
                            }
                            else
                            {
                                <div style="width:100%; height:160px; background:linear-gradient(135deg,var(--eh-navy) 0%,var(--eh-navy-mid) 100%); display:flex; align-items:center; justify-content:center;">
                                    <span style="color:rgba(255,255,255,0.55); font-size:0.9rem; font-weight:500;">@car.Make @car.Model</span>
                                </div>
                            }
                            <div class="p-4 d-flex flex-column h-100">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h5 class="fw-bold mb-0">@car.Make @car.Model</h5>
                                    @if (car.IsAvailable)
                                    {
                                        <span class="badge-available">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge-unavailable">Unavailable</span>
                                    }
                                </div>
                                <p class="text-muted mb-1" style="font-size:0.8rem;">Car ID: #@car.Id &nbsp;&bull;&nbsp; Reg: @car.Registration &nbsp;&bull;&nbsp; @car.Seats seats</p>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-3">
                                    <span class="price-accent" style="font-size:1.3rem">£@car.PricePerDay<span style="font-size:0.8rem; color:#64748b; font-weight:400">/day</span></span>
                                    @if (car.IsAvailable)
                                    {
                                        <a href="/Booking?carId=@car.Id" class="btn btn-navy btn-sm">Book Now</a>
                                    }
                                    else
                                    {
                                        <span class="btn btn-sm" style="background:#f1f5f9; color:#94a3b8; cursor:not-allowed;">Unavailable</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
